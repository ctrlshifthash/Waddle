# ----- Client (Vite) -----
# Privy app id (https://dashboard.privy.io) — required for wallet login
VITE_PRIVY_APP_ID=your-privy-app-id
# Where the Phaser client connects to the Colyseus server
VITE_GAME_WS_URL=ws://localhost:2567

# ----- Server (Colyseus) -----
PORT=2567
# Solana settle layer (only needed when you turn on real on-chain payouts)
SOLANA_RPC_URL=https://api.devnet.solana.com
# Base58 secret key of the treasury wallet that holds/mints the coin token
SOLANA_TREASURY_SECRET=
# SPL token mint address that represents in-game coins on-chain
SOLANA_COIN_MINT=
# Set to "true" to actually push coin payouts on-chain (off = ledger only)
SOLANA_SETTLE_ENABLED=false
